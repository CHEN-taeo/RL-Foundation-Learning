# 主题：QN完整loop跑通CartPole，验证收敛(小车倒立摆）
# 内容：通过给小车施加向左或向右的力，让杆子保持竖直
# 功能：通过学习这节知识可以融会贯通单智能体的DQN与Q_learning算法，理解它们的核心逻辑，并且能够在CartPole-v1环境中成功训练一个智能体，使其能够保持杆子竖直，达到收敛的目标。
# 时间：2026-05-07   
# 作者：陈韬   

# 导入库：numpy（数据处理库），torch和torch.nn(神经网络与优化器），gymnasium（CartPole环境），ReplayBuffer（经验回放池）
import gymnasium as gym
import numpy as np
from train_target import train  # 从模块中导入train函数
import matplotlib.pyplot as plt     # 导入画图库
from ReplayBuffer import ReplayBuffer  # 从模块中导入ReplayBuffer类
import torch
from dqn_v0 import SimpleDQN

# 解决中文乱码问题
plt.rcParams['font.sans-serif'] = ['SimHei']  # 设置中文字体为黑体
plt.rcParams['axes.unicode_minus'] = False  # 解决负号显示问题


# 定义动作选择函数
def epsilon_greedy_action(online_net,state,epsilon,n_actions):

    state_tensor = torch.tensor(state, dtype=torch.float32).unsqueeze(0)  # 预处理
    with torch.no_grad():
        q_value=online_net(state_tensor)    # 网络输出q_value
    action=q_value.argmax(dim=1).item() # 取最优动作
    rand_num=np.random.random()   # 随机生成0-1的数
    if rand_num<epsilon:
        action=np.random.choice(n_actions)    # 和epsilon相比，小就随机选动作，大就选最优动作
    return action

# 超参数初始化
env=gym.make('CartPole-v1',render_mode="")   # 构建环境
max_episodes=800   # 最大回合数
batch_size=32   # 一批次中的数据量
gamma=0.99  # 未来折扣
Ir=0.001  # 学习率
epsilon_start=1     # 开始时的探索概率
epsilon_min=0.01    # 最小探索概率
epsilon_decay=0.995  # 探索概率衰减量
update_target_every=10  # 每次更新目标
epsilon=1   # 探索概率
window_size=100

# 在线网络与目标网络
online_net=SimpleDQN()  # SimpleDQN是我之前写的网络类，输入4个状态，输出两个动作
target_net=SimpleDQN()

# 目标网络权重初始权重同步
target_net.load_state_dict(online_net.state_dict())
optimiser=torch.optim.Adam(online_net.parameters(),lr=Ir)    # 优化器
buffer=ReplayBuffer(10000)  # 回放池
global_step=0
episode_rewards=[]  # 全局变量


# 绘制收敛曲线，初始化图表
plt.ion()   # 开启实时交互模式，这样图表就可以边训练边绘制了
plt.figure(figsize=(10,6))  # 创建画布，长为6，宽为10.单位英尺
line, =plt.plot([],[],label="奖励值",color="blue",linewidth=4)  # 初始化空线，返回line对象
plt.title("奖励收敛曲线",fontsize=10)   # 写标题
plt.xlabel("episode",fontsize=10)
plt.ylabel("reward",fontsize=10)
plt.legend(fontsize=10)     # 加图例（显示每条线的名称）
plt.grid(alpha=0.3)     # 加网格。alpha是透明度
plt.xlim(0, max_episodes)  # 设置x轴范围
plt.ylim(0, 500)  # 设置y轴范围



# 主循环的完整逻辑
for episode in range(max_episodes):  # 外层循环
    state,_=env.reset()
    done=False
    episode_reward=0    # 初始化
    while not done:     # 内层循环

        action=epsilon_greedy_action(online_net,state,epsilon,env.action_space.n)   # step交互
        next_state, reward, terminated, truncated, _ = env.step(action)  # 获取周围环境信息
        done=terminated or truncated    # done的值由terminated和truncated共同决定
        buffer.push(state,action,reward,next_state,done)  # 把当前状态、动作、奖励、下一个状态和done存进回放池
        episode_reward += reward  # 累加奖励值
        state = next_state  # 更新状态
        global_step += 1  # 回合数加1
        if len(buffer) > batch_size:  # 判断是否训练
            train(online_net, target_net, buffer, optimiser, batch_size, gamma)
        if global_step % update_target_every == 0:  # 判断是否同步目标网络
            target_net.load_state_dict(online_net.state_dict())


    episode_rewards.append(episode_reward)  # 存进列表
    if len(episode_rewards)>=window_size:   # 确保数据足够
        smoothed_reward=np.convolve(episode_rewards,np.ones(window_size)/window_size,mode="valid")  # 计算滑动平均
        x_data = np.arange(window_size-1,len(episode_rewards))  # x轴：episode曲线
        line.set_data(x_data,smoothed_reward)  # 绘制曲线的x轴与y轴
        plt.draw()  # 刷新图表
        plt.pause(0.01)  # 短暂停留，让图表显示
        epsilon=max(epsilon_min,epsilon*epsilon_decay)  # epsilon衰减（不是线性减0.01）
    if len(episode_rewards)>=100:
        final_reward=np.mean(episode_rewards[-100:])    # 算最近100个的滑动平均奖励
        if final_reward>=475:
            print("训练成功！！！")

    # 打印每回合的训练日志
    avg_reward = np.mean(episode_rewards[-100:]) if len(episode_rewards) >= 100 else 'N/A'
    print(
        f"Episode {episode + 1} | Reward: {episode_reward} | Avg Reward (Last 100): {avg_reward} | Epsilon: {epsilon:.4f} | Global Step: {global_step}")

# 保存图片
plt.savefig("dqn_CartPole-v1_figure.png",dpi=300)   # 保存图片。dpi是清晰度
plt.ioff()  # 关闭交互模式
plt.show()
